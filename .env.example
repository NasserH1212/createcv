# ─── CreateCV Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.

# Anthropic API key — enables real AI resume analysis.
# Without it, the app runs in demo mode with sample feedback.
ANTHROPIC_API_KEY=

# Server port (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins.
# Required in production. Default: http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# Environment mode (development or production)
NODE_ENV=development
